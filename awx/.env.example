# AWX Environment Variables
# Copy to .env and customize

# Database
AWX_DB_PASSWORD=change_me_secure_password

# Admin credentials (CHANGE THESE!)
AWX_ADMIN_USER=admin
AWX_ADMIN_PASSWORD=change_me_immediately
AWX_ADMIN_EMAIL=admin@yourcompany.com

# Secret key for Django (generate with: openssl rand -base64 32)
AWX_SECRET_KEY=generate_a_secure_random_key_here

# Web port
AWX_WEB_PORT=8052

# Pushgateway port
PUSHGATEWAY_PORT=9091

# Optional: Webhook URL for maintenance notifications
# Supports Slack, Teams, or any JSON webhook
MAINTENANCE_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Optional: Base URL for AWX (for email links)
TOWER_URL_BASE=http://localhost:8052
