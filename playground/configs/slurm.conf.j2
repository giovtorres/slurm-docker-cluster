# slurm.conf - Slurm configuration file (Generated from template)
# Generated by: playground scale command
# Timestamp: {{ timestamp }}
#
# See slurm.conf(5) for more information.

#
# Cluster Identity
#
ClusterName={{ cluster_name | default('playground') }}
SlurmctldHost=slurmctld

#
# Authentication
#
AuthType=auth/munge

#
# Paths
#
SlurmctldPidFile=/var/run/slurm/slurmctld.pid
SlurmctldPort=6817
SlurmdPidFile=/var/run/slurm/slurmd.pid
SlurmdPort=6818
SlurmdSpoolDir=/var/spool/slurm
SlurmUser=slurm
StateSaveLocation=/var/lib/slurm

#
# Process Tracking
#
ProctrackType=proctrack/linuxproc
TaskPlugin=task/affinity

#
# Timers
#
InactiveLimit={{ inactive_limit | default(0) }}
KillWait={{ kill_wait | default(30) }}
MinJobAge={{ min_job_age | default(300) }}
SlurmctldTimeout={{ slurmctld_timeout | default(120) }}
SlurmdTimeout={{ slurmd_timeout | default(300) }}
Waittime={{ wait_time | default(0) }}

#
# Scheduling
#
SchedulerType=sched/{{ scheduler | default('backfill') }}
SelectType=select/cons_tres
SelectTypeParameters={{ select_params | default('CR_Core_Memory') }}
{% if preempt_mode %}
PreemptType=preempt/{{ preempt_type | default('partition_prio') }}
PreemptMode={{ preempt_mode }}
{% endif %}
{% if fair_share %}
PriorityType=priority/multifactor
PriorityDecayHalfLife={{ priority_decay | default('7-0') }}
PriorityFavorSmall={{ priority_favor_small | default('NO') }}
PriorityWeightAge={{ priority_weight_age | default(1000) }}
PriorityWeightFairshare={{ priority_weight_fairshare | default(10000) }}
PriorityWeightJobSize={{ priority_weight_jobsize | default(1000) }}
PriorityWeightPartition={{ priority_weight_partition | default(1000) }}
{% endif %}

#
# Service Behavior
#
ReturnToService={{ return_to_service | default(1) }}

#
# Accounting
#
AccountingStorageHost=slurmdbd
AccountingStorageType=accounting_storage/slurmdbd
JobCompLoc=/var/log/slurm/jobcomp.log
JobCompType=jobcomp/filetxt
JobAcctGatherType=jobacct_gather/linux
JobAcctGatherFrequency={{ job_acct_frequency | default(30) }}

#
# Logging
#
SlurmctldDebug={{ slurmctld_debug | default('info') }}
SlurmctldLogFile=/var/log/slurm/slurmctld.log
SlurmdDebug={{ slurmd_debug | default('info') }}
SlurmdLogFile=/var/log/slurm/slurmd.log

{% if gres_types %}
#
# Generic Resources (GRES)
#
GresTypes={{ gres_types | join(',') }}
{% endif %}

#
# Compute Nodes
#
{% for node in nodes %}
NodeName={{ node.name }} CPUs={{ node.cpus }} RealMemory={{ node.memory }}{% if node.features %} Features={{ node.features | join(',') }}{% endif %}{% if node.gres %} Gres={{ node.gres }}{% endif %} State=UNKNOWN
{% endfor %}

#
# Partitions
#
{% for partition in partitions %}
PartitionName={{ partition.name }} Nodes={{ partition.nodes | join(',') }}{% if partition.default %} Default=YES{% endif %}{% if partition.max_time %} MaxTime={{ partition.max_time }}{% else %} MaxTime=INFINITE{% endif %}{% if partition.priority %} PriorityTier={{ partition.priority }}{% endif %}{% if partition.preempt_mode %} PreemptMode={{ partition.preempt_mode }}{% endif %} State=UP
{% endfor %}
